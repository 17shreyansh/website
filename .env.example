# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=RSD Bharti Industries

# Contact Information
NEXT_PUBLIC_CONTACT_EMAIL=info@rsdbharti.com
NEXT_PUBLIC_CONTACT_PHONE=+91 98765 43210

# Google Maps API (Optional - for map integration)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here

# Analytics (Optional)
# NEXT_PUBLIC_GA_TRACKING_ID=your_ga_id_here

# Form Submission (Optional - for contact form backend)
# NEXT_PUBLIC_FORM_ENDPOINT=your_form_endpoint_here
